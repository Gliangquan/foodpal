services:
  foodpal-mysql:
    image: mysql:8.0
    container_name: foodpal-mysql
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: foodpal_root_2026
      MYSQL_DATABASE: foodpal
      MYSQL_USER: foodpal
      MYSQL_PASSWORD: foodpal_2026
      TZ: Asia/Shanghai
    command:
      - --character-set-server=utf8mb4
      - --collation-server=utf8mb4_unicode_ci
      - --default-authentication-plugin=mysql_native_password
    volumes:
      - foodpal_mysql_data:/var/lib/mysql
      - ./food-backend/sql/init_foodpal.sql:/docker-entrypoint-initdb.d/01-init_foodpal.sql:ro
      - ./food-backend/sql/migration_add_user_gender_age.sql:/docker-entrypoint-initdb.d/02-migration_add_user_gender_age.sql:ro
      - ./food-backend/sql/seed_foodpal_full.sql:/docker-entrypoint-initdb.d/03-seed_foodpal_full.sql:ro
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "127.0.0.1", "-uroot", "-pfoodpal_root_2026"]
      interval: 10s
      timeout: 5s
      retries: 10

  foodpal-minio:
    image: minio/minio:latest
    container_name: foodpal-minio
    restart: unless-stopped
    environment:
      MINIO_ROOT_USER: foodpalminio
      MINIO_ROOT_PASSWORD: foodpalminio2026
    command: server /data --console-address ":9001"
    volumes:
      - foodpal_minio_data:/data

  foodpal-backend:
    build:
      context: ./food-backend
    container_name: foodpal-backend
    restart: unless-stopped
    depends_on:
      foodpal-mysql:
        condition: service_healthy
      foodpal-minio:
        condition: service_started
    environment:
      TZ: Asia/Shanghai
      DATASOURCE_URL: jdbc:mysql://foodpal-mysql:3306/foodpal?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=UTF-8
      DATASOURCE_USERNAME: foodpal
      DATASOURCE_PASSWORD: foodpal_2026
      MINIO_ENDPOINT: http://foodpal-minio:9000
      MINIO_ACCESS_KEY: foodpalminio
      MINIO_SECRET_KEY: foodpalminio2026
      MINIO_BUCKET_NAME: foodpal-project
      JWT_SECRET: foodpal-jwt-secret-please-change-in-production-2026-very-long
    ports:
      - "9040:9901"

  foodpal-frontend:
    build:
      context: ./food-frontend
    container_name: foodpal-frontend
    restart: unless-stopped
    depends_on:
      - foodpal-backend
    ports:
      - "9041:80"

  foodpal-uniapp-h5:
    build:
      context: ./food-uniapp
      dockerfile: Dockerfile.h5
    container_name: foodpal-uniapp-h5
    restart: unless-stopped
    depends_on:
      - foodpal-backend
    ports:
      - "9042:8080"

volumes:
  foodpal_mysql_data:
  foodpal_minio_data:
